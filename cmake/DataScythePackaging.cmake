set(CPACK_PACKAGE_NAME "DataScythe")
set(CPACK_PACKAGE_VENDOR "DataScythe")
set(CPACK_PACKAGE_VERSION ${PROJECT_VERSION})
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "Secure data erasure for drives, volumes, and files")
set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_SOURCE_DIR}/LICENSE.md")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "DataScythe")

if(WIN32)
    set(CPACK_GENERATOR "ZIP")
    set(CPACK_PACKAGE_FILE_NAME "DataScythe-${PROJECT_VERSION}-win64")
elseif(APPLE)
    set(CPACK_GENERATOR "TGZ")
    set(CPACK_PACKAGE_FILE_NAME "DataScythe-${PROJECT_VERSION}-macos")
else()
    set(CPACK_GENERATOR "TGZ")
    set(CPACK_PACKAGE_FILE_NAME "DataScythe-${PROJECT_VERSION}-linux-amd64")
endif()